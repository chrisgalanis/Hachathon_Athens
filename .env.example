# === LLM Configuration ===
# Provider: anthropic | openai | google | groq | mistral
LLM_PROVIDER=anthropic
# Full model ID as the provider expects it
LLM_MODEL=claude-sonnet-4-20250514

# === API Keys (set the one matching your provider) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# === Fish Audio (voice synthesis) ===
FISH_AUDIO_API_KEY=
# Optional override (default: s1)
FISH_AUDIO_MODEL=
# Optional voice reference ID (clone/custom voice from fish.audio)
FISH_AUDIO_REFERENCE_ID=
