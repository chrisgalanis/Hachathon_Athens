# === LLM Configuration ===
# Provider: anthropic | openai | google | groq | mistral
LLM_PROVIDER=anthropic
# Full model ID as the provider expects it
LLM_MODEL=claude-sonnet-4-20250514

# === API Keys (set the one matching your provider) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# === ElevenLabs (voice synthesis) ===
ELEVENLABS_API_KEY=
# Optional overrides (defaults: Aria voice, eleven_multilingual_v2)
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
